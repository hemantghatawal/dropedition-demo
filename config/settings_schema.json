[
  {
    "name": "theme_info",
    "theme_name": "Skeleton",
    "theme_version": "0.1.0",
    "theme_author": "Shopify",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "inter_n4",
        "label": "t:general.primary"
      },
      {
        "type": "range",
        "id": "font_size_base",
        "min": 14,
        "max": 20,
        "step": 1,
        "unit": "px",
        "label": "t:labels.font_size_base",
        "default": 16
      }
    ]
  },
  {
    "name": "t:general.colors",
    "settings": [
      {
        "type": "color",
        "id": "color_background",
        "default": "#FFFFFF",
        "label": "t:labels.background"
      },
      {
        "type": "color",
        "id": "color_foreground",
        "default": "#1A1A1A",
        "label": "t:labels.foreground"
      },
      {
        "type": "color",
        "id": "color_primary",
        "default": "#1A1A1A",
        "label": "t:labels.color_primary"
      },
      {
        "type": "color",
        "id": "color_secondary",
        "default": "#F5F5F0",
        "label": "t:labels.color_secondary"
      },
      {
        "type": "color",
        "id": "color_accent",
        "default": "#C8A96E",
        "label": "t:labels.color_accent"
      },
      {
        "type": "color",
        "id": "color_dark_bg",
        "default": "#1A1A1A",
        "label": "t:labels.color_dark_bg"
      },
      {
        "type": "color",
        "id": "color_text_light",
        "default": "#FFFFFF",
        "label": "t:labels.color_text_light"
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          {
            "value": "90rem",
            "label": "t:options.page_width.narrow"
          },
          {
            "value": "110rem",
            "label": "t:options.page_width.wide"
          }
        ],
        "default": "110rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 24
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "t:labels.input_corner_radius",
        "default": 0
      }
    ]
  },
  {
    "name": "t:general.spacing",
    "settings": [
      {
        "type": "range",
        "id": "space_xs",
        "min": 4,
        "max": 12,
        "step": 2,
        "unit": "px",
        "label": "t:labels.space_xs",
        "default": 4
      },
      {
        "type": "range",
        "id": "space_sm",
        "min": 8,
        "max": 24,
        "step": 4,
        "unit": "px",
        "label": "t:labels.space_sm",
        "default": 8
      },
      {
        "type": "range",
        "id": "space_md",
        "min": 16,
        "max": 48,
        "step": 4,
        "unit": "px",
        "label": "t:labels.space_md",
        "default": 24
      },
      {
        "type": "range",
        "id": "space_lg",
        "min": 32,
        "max": 96,
        "step": 8,
        "unit": "px",
        "label": "t:labels.space_lg",
        "default": 48
      },
      {
        "type": "range",
        "id": "space_xl",
        "min": 64,
        "max": 160,
        "step": 8,
        "unit": "px",
        "label": "t:labels.space_xl",
        "default": 96
      }
    ]
  }
]