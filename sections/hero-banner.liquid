{%- comment -%}
  Hero Banner — Premium Editorial Scroll Animation
  - Scroll-driven text mask reveal effect
  - Background image fades out via white overlay
  - SVG text mask reveals sharp, high-contrast version of same image
  - Creates luxury editorial "reflection illusion" effect
{%- endcomment -%}

{%- liquid
  assign scroll_height = section.settings.scroll_height | default: 150
  assign mask_start_size = section.settings.mask_start_size | default: 80
  assign mask_end_size = section.settings.mask_end_size | default: 110
  assign overlay_opacity = section.settings.overlay_opacity | default: 80
  assign parallax_amount = section.settings.parallax_amount | default: 20
-%}

<div
  class="hero-scroll-container full-width"
  id="hero-scroll-container"
  data-scroll-height="{{ scroll_height }}"
  data-mask-start="{{ mask_start_size }}"
  data-mask-end="{{ mask_end_size }}"
  data-overlay-opacity="{{ overlay_opacity }}"
  data-parallax="{{ parallax_amount }}"
  data-logo-desktop="{{ 'logo.svg' | asset_url }}"
  data-logo-mobile="{{ 'logo-s.svg' | asset_url }}"
>
  <div class="hero-sticky-wrapper" id="hero-sticky-wrapper">
    {%- comment -%} Background layer with overlay {%- endcomment -%}
    <div class="hero-bg-wrapper">
      {%- comment -%} Base background image (will fade out) {%- endcomment -%}
      <div class="hero-bg">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 2400 }}"
            alt="{{ section.settings.image.alt | escape }}"
            class="hero-bg__image"
            loading="eager"
            fetchpriority="high"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
          >
        {%- else -%}
          <img
            src="{{ 'hero-banner.jpg' | asset_url }}"
            alt=""
            class="hero-bg__image"
            loading="eager"
            fetchpriority="high"
            width="2400"
            height="1350"
          >
        {%- endif -%}
      </div>

      {%- comment -%} White overlay (fades in during scroll, only affects background) {%- endcomment -%}
      <div class="hero-overlay" id="hero-overlay"></div>
    </div>

    {%- comment -%} SVG mask container (reveals sharp image through text) {%- endcomment -%}
    <div class="hero-mask" id="hero-mask">
      {%- if section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 2400 }}"
          alt=""
          class="hero-mask__image"
          id="hero-mask-image"
          loading="eager"
          width="{{ section.settings.image.width }}"
          height="{{ section.settings.image.height }}"
        >
      {%- else -%}
        <img
          src="{{ 'hero-banner.jpg' | asset_url }}"
          alt=""
          class="hero-mask__image"
          id="hero-mask-image"
          loading="eager"
          width="2400"
          height="1350"
        >
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  /* ── Scroll container — provides scroll room for animation ── */
  .hero-scroll-container {
    position: relative;
    width: 100%;
    /* height set by JS based on scroll_height setting */
  }

  /* ── Sticky wrapper — stays fixed during scroll ── */
  .hero-sticky-wrapper {
    position: sticky;
    top: 0;
    width: 100%;
    height: 100vh;
    min-height: 600px;
    overflow: hidden;
  }

  /* ── Background wrapper — contains bg image + overlay ── */
  .hero-bg-wrapper {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  /* ── Base background layer ── */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    will-change: transform;
  }

  /* ── White overlay — only affects background, NOT the mask ── */
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background-color: #ffffff;
    opacity: 0;
    pointer-events: none;
    will-change: opacity;
  }

  /* ── SVG mask container — separate layer, unaffected by overlay ── */
  .hero-mask {
    position: absolute;
    inset: 0;
    z-index: 10;
    pointer-events: none;
    background: transparent;
    opacity: 0;

    /* SVG mask applied via inline style in JS */
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
    transform-origin: center center;
    will-change: transform, opacity;
  }

  /* ── Shimmer on the masked image ── */
  @keyframes hero-mask-shimmer {
    0%,
    100% {
      filter: contrast(1.15) saturate(1.1) brightness(1.05);
    }
    50% {
      filter: contrast(1.2) saturate(1.18) brightness(1.12);
    }
  }

  .hero-mask__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;

    /* Enhanced contrast for masked image */
    filter: contrast(1.15) saturate(1.1) brightness(1.05);
    will-change: transform, filter;
    animation: hero-mask-shimmer 4s ease-in-out infinite;
  }

  /* ── Mobile adjustments ── */
  @media (max-width: 768px) {
    .hero-sticky-wrapper {
      min-height: 500px;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var container = document.getElementById('hero-scroll-container');
    var wrapper = document.getElementById('hero-sticky-wrapper');
    var overlay = document.getElementById('hero-overlay');
    var mask = document.getElementById('hero-mask');
    var maskImage = document.getElementById('hero-mask-image');

    if (!container || !wrapper || !overlay || !mask || !maskImage) return;

    /* ── Config from data attributes ── */
    var scrollHeightVh = parseInt(container.getAttribute('data-scroll-height')) || 150;
    var maskStartSize = parseInt(container.getAttribute('data-mask-start')) || 80;
    var maskEndSize = parseInt(container.getAttribute('data-mask-end')) || 110;
    var parallaxAmount = parseInt(container.getAttribute('data-parallax')) || 20;

    /* ── SVG mask ── */
    var logoDesktop = container.getAttribute('data-logo-desktop');
    var logoMobile = container.getAttribute('data-logo-mobile');
    var isMobile = window.innerWidth <= 768;
    var logoUrl = isMobile ? logoMobile : logoDesktop;

    function applyMaskUrl() {
      mask.style.webkitMaskImage = 'url(' + logoUrl + ')';
      mask.style.maskImage = 'url(' + logoUrl + ')';
    }
    applyMaskUrl();

    /* ── Dimensions ── */
    var viewportHeight = window.innerHeight;
    var containerTop = 0;
    var scrollRoom = (scrollHeightVh / 100) * viewportHeight;
    container.style.height = viewportHeight + scrollRoom + 'px';

    function cacheContainerTop() {
      containerTop = container.getBoundingClientRect().top + window.scrollY;
    }
    cacheContainerTop();

    /* ── Helpers ── */
    function clamp(v, lo, hi) {
      return Math.min(Math.max(v, lo), hi);
    }
    function lerp(a, b, t) {
      return a + (b - a) * t;
    }

    /* ── Smoothed display values ── */
    var currentMaskSize = maskStartSize;
    var currentOverlay = 0;
    var currentParallax = 0;
    var currentMaskOpacity = 0;

    /* ── Targets driven by scroll ── */
    var targetMaskSize = maskStartSize;
    var targetOverlay = 0;
    var targetParallax = 0;
    var targetMaskOpacity = 0;

    var SMOOTH = 0.08;
    var SMOOTH_OPACITY = 0.05;
    var rafId = null;

    /* ── Read scroll ── */
    function readScroll() {
      var scrolled = window.scrollY - containerTop;
      var progress = clamp(scrolled / scrollRoom, 0, 1);

      var t = progress < 0.5 ? 4 * progress * progress * progress : 1 - Math.pow(-2 * progress + 2, 3) / 2;

      targetOverlay = t * 0.8;
      targetMaskSize = lerp(maskStartSize, maskEndSize, t);
      targetParallax = t * parallaxAmount;
      targetMaskOpacity = clamp(progress / 0.15, 0, 1);
    }

    /* ── Write frame ── */
    function writeFrame() {
      rafId = null;

      currentOverlay = lerp(currentOverlay, targetOverlay, SMOOTH);
      currentMaskSize = lerp(currentMaskSize, targetMaskSize, SMOOTH);
      currentParallax = lerp(currentParallax, targetParallax, SMOOTH);
      currentMaskOpacity = lerp(currentMaskOpacity, targetMaskOpacity, SMOOTH_OPACITY);

      overlay.style.opacity = currentOverlay.toFixed(4);
      mask.style.opacity = currentMaskOpacity.toFixed(4);

      var scale = currentMaskSize / maskStartSize;
      mask.style.transform = 'scale(' + scale.toFixed(4) + ')';

      maskImage.style.transform =
        'translateY(' + currentParallax.toFixed(3) + '%) scale(' + (1 / scale).toFixed(4) + ')';

      var stillMoving =
        Math.abs(currentOverlay - targetOverlay) > 0.0001 ||
        Math.abs(currentMaskSize - targetMaskSize) > 0.01 ||
        Math.abs(currentParallax - targetParallax) > 0.01 ||
        Math.abs(currentMaskOpacity - targetMaskOpacity) > 0.0005;

      if (stillMoving) rafId = requestAnimationFrame(writeFrame);
    }

    function kick() {
      if (!rafId) rafId = requestAnimationFrame(writeFrame);
    }

    /* ── Scroll handler ── */
    function onScroll() {
      readScroll();
      kick();
    }
    function onResize() {
      isMobile = window.innerWidth <= 768;
      logoUrl = isMobile ? logoMobile : logoDesktop;
      applyMaskUrl();

      viewportHeight = window.innerHeight;
      scrollRoom = (scrollHeightVh / 100) * viewportHeight;
      container.style.height = viewportHeight + scrollRoom + 'px';
      cacheContainerTop();
      onScroll();
    }

    /* ── Init ── */
    mask.style.webkitMaskSize = maskStartSize + '%';
    mask.style.maskSize = maskStartSize + '%';
    mask.style.transformOrigin = 'center center';
    maskImage.style.transformOrigin = 'center center';
    overlay.style.opacity = '0';

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onResize, { passive: true });

    readScroll();
    kick();
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.hero_mask.name",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.hero_mask.image",
      "info": "t:sections.hero_mask.image_info"
    },
    {
      "type": "header",
      "content": "t:sections.hero_mask.animation_settings"
    },
    {
      "type": "range",
      "id": "scroll_height",
      "min": 50,
      "max": 500,
      "step": 50,
      "unit": "vh",
      "label": "t:sections.hero_mask.scroll_height",
      "info": "t:sections.hero_mask.scroll_height_info",
      "default": 150
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "t:sections.hero_mask.overlay_opacity",
      "info": "t:sections.hero_mask.overlay_opacity_info",
      "default": 80
    },
    {
      "type": "range",
      "id": "mask_start_size",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "t:sections.hero_mask.mask_start_size",
      "default": 80
    },
    {
      "type": "range",
      "id": "mask_end_size",
      "min": 100,
      "max": 150,
      "step": 5,
      "unit": "%",
      "label": "t:sections.hero_mask.mask_end_size",
      "default": 110
    },
    {
      "type": "range",
      "id": "parallax_amount",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "%",
      "label": "t:sections.hero_mask.parallax_amount",
      "info": "t:sections.hero_mask.parallax_amount_info",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "t:sections.hero_mask.name"
    }
  ]
}
{% endschema %}
