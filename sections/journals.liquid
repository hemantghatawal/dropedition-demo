<section class="journals full-width" id="journals">
  {%- comment -%} Label sits above the two columns {%- endcomment -%}
  <div class="journals__header">
    <span class="journals__label">{{- section.settings.heading | escape -}}</span>
  </div>

  <div class="journals__inner">
    {%- comment -%} Left: main image {%- endcomment -%}
    <div class="journals__left">
      <div class="journals__main-img-wrap">
        {%- if section.settings.main_image != blank -%}
          <img
            src="{{ section.settings.main_image | image_url: width: 1200 }}"
            alt=""
            class="journals__main-img"
            loading="lazy"
            width="{{ section.settings.main_image.width }}"
            height="{{ section.settings.main_image.height }}"
          >
        {%- else -%}
          <img
            src="{{ 'journal-main.jpg' | asset_url }}"
            alt=""
            class="journals__main-img"
            loading="lazy"
            width="1200"
            height="800"
          >
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Right: vertical auto-scroll strip {%- endcomment -%}
    <div class="journals__right">
      <div class="journals__track" id="journals-track">
        {%- for i in (1..6) -%}
          <div class="journals__item">
            <img
              src="{{ 'journal-' | append: i | append: '.avif' | asset_url }}"
              alt=""
              class="journals__img"
              loading="lazy"
              width="600"
              height="400"
            >
          </div>
        {%- endfor -%}
        {%- comment -%} Clone for seamless loop {%- endcomment -%}
        {%- for i in (1..6) -%}
          <div class="journals__item" aria-hidden="true">
            <img
              src="{{ 'journal-' | append: i | append: '.avif' | asset_url }}"
              alt=""
              class="journals__img"
              loading="lazy"
              width="600"
              height="400"
            >
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .journals {
    width: 100%;
    background: var(--color-background, #fff);
    font-family: var(--font-primary);
    padding-bottom: var(--space-xl);
  }

  /* ── Label above columns ── */
  .journals__header {
    padding: var(--space-lg) var(--space-lg);
    border-bottom: 1px solid rgba(0, 0, 0, 0.12);
  }

  .journals__label {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-regular);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-text);
  }

  /* ── Two-column layout: 70% left / 30% right, 50px gap ── */
  .journals__inner {
    display: grid;
    grid-template-columns: 1fr 30%;
    gap: 50px;
    height: 75vh;
    padding: 0 50px;
  }

  /* ── Left: square image ── */
  .journals__left {
    overflow: hidden;
    /* aspect-ratio: 1 / 1; */
    height: auto;
    align-self: center;
  }

  .journals__main-img-wrap {
    width: 100%;
    height: 100%;
  }

  .journals__main-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* ── Right: clipped scroll strip ── */
  .journals__right {
    overflow: hidden;
    height: 75vh;
  }

  .journals__track {
    display: flex;
    flex-direction: column;
    gap: 20px;
    will-change: transform;
  }

  .journals__item {
    flex: 0 0 auto;
    width: 100%;
    overflow: hidden;
  }

  .journals__img {
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    object-position: center;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .journals__inner {
      grid-template-columns: 1fr;
      height: auto;
    }

    .journals__left {
      height: 360px;
    }

    .journals__right {
      height: 400px;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var track = document.getElementById('journals-track');
    if (!track) return;

    var BASE_SPEED = 0.5;
    var MAX_BOOST = 8;
    var DECAY = 0.9;
    var GAP = 20;

    var halfHeight = 0;
    var position = 0;
    var boost = 0;
    var lastY = window.scrollY;

    function measure() {
      var items = track.querySelectorAll('.journals__item');
      var half = Math.floor(items.length / 2);
      var h = 0;
      for (var i = 0; i < half; i++) {
        h += items[i].offsetHeight + GAP;
      }
      return h;
    }

    function tick() {
      /* Track moves downward → images travel top to bottom */
      position += BASE_SPEED + boost;

      /* Once second set fully enters view, snap back by one set */
      if (halfHeight > 0 && position >= 0) {
        position -= halfHeight;
      }

      track.style.transform = 'translateY(' + position + 'px)';

      boost *= DECAY;
      if (boost < 0.01) boost = 0;

      requestAnimationFrame(tick);
    }

    window.addEventListener(
      'scroll',
      function () {
        var delta = Math.abs(window.scrollY - lastY);
        boost = Math.min(boost + delta * 0.06, MAX_BOOST);
        lastY = window.scrollY;
      },
      { passive: true }
    );

    window.addEventListener('resize', function () {
      halfHeight = measure();
    });

    function init() {
      halfHeight = measure();
      if (halfHeight === 0) {
        requestAnimationFrame(init);
        return;
      }
      /* Start shifted up by one full set so images scroll into view from top */
      position = -halfHeight;
      tick();
    }

    if (document.readyState === 'complete') {
      requestAnimationFrame(init);
    } else {
      window.addEventListener('load', function () {
        requestAnimationFrame(init);
      });
    }
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.journals.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.journals.heading",
      "default": "Journals"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "t:sections.journals.main_image"
    }
  ],
  "presets": [
    {
      "name": "t:sections.journals.name"
    }
  ]
}
{% endschema %}
