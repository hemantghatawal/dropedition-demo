<section class="sort-by-type full-width" id="sort-by-type">
  <div class="sort-by-type__header">
    <span class="sort-by-type__label">{{- section.settings.heading | escape -}}</span>
  </div>

  <div class="sort-by-type__track-wrapper">
    <div class="sort-by-type__track" id="sort-by-type-track">
      {%- for i in (1..6) -%}
        <div class="sort-by-type__item">
          <img
            src="{{ 'sort-by-type-' | append: i | append: '.avif' | asset_url }}"
            alt=""
            class="sort-by-type__img"
            loading="lazy"
            width="400"
            height="560"
          >
        </div>
      {%- endfor -%}
      {%- comment -%} Duplicate for seamless loop {%- endcomment -%}
      {%- for i in (1..6) -%}
        <div class="sort-by-type__item" aria-hidden="true">
          <img
            src="{{ 'sort-by-type-' | append: i | append: '.avif' | asset_url }}"
            alt=""
            class="sort-by-type__img"
            loading="lazy"
            width="400"
            height="560"
          >
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .sort-by-type {
    width: 100%;
    overflow: hidden;
    background: var(--color-background, #fff);
    font-family: var(--font-primary);
    padding-bottom: var(--space-xl);
  }

  /* ── Header ── */
  .sort-by-type__header {
    padding: var(--space-lg) var(--page-margin);
    border-bottom: 1px solid currentColor;
    margin-bottom: var(--space-lg);
  }

  .sort-by-type__label {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-regular);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-text);
  }

  /* ── Scrolling track ── */
  .sort-by-type__track-wrapper {
    overflow: hidden;
    width: 100%;
  }

  .sort-by-type__track {
    display: flex;
    gap: 12px;
    width: max-content;
    will-change: transform;
  }

  /* ── Individual image card ── */
  .sort-by-type__item {
    flex: 0 0 auto;
    width: 30vw;
    overflow: hidden;
  }

  .sort-by-type__img {
    display: block;
    width: 100%;
    height: 90vh;
    object-fit: cover;
    object-position: center;
  }

  @media (max-width: 768px) {
    .sort-by-type__item {
      width: 200px;
    }

    .sort-by-type__img {
      height: 440px;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var track = document.getElementById('sort-by-type-track');
    if (!track) return;

    var baseSpeed = 0.6; /* px per frame at rest */
    var scrollBoost = 0; /* extra speed added on scroll */
    var scrollDecay = 0.92; /* how fast the boost fades */
    var position = 0;
    var halfWidth = 0;
    var lastScrollY = window.scrollY;
    var raf;

    function calcHalf() {
      /* half = width of one set of 6 images + gaps */
      var items = track.querySelectorAll('.sort-by-type__item');
      var count = items.length / 2;
      var total = 0;
      for (var i = 0; i < count; i++) {
        total += items[i].offsetWidth + 12; /* 12px gap */
      }
      halfWidth = total;
    }

    function tick() {
      var speed = baseSpeed + scrollBoost;
      position -= speed;

      /* Reset when first set fully scrolled out */
      if (halfWidth > 0 && Math.abs(position) >= halfWidth) {
        position += halfWidth;
      }

      track.style.transform = 'translateX(' + position + 'px)';

      /* Decay the scroll boost */
      scrollBoost *= scrollDecay;
      if (scrollBoost < 0.01) scrollBoost = 0;

      raf = requestAnimationFrame(tick);
    }

    window.addEventListener(
      'scroll',
      function () {
        var delta = Math.abs(window.scrollY - lastScrollY);
        scrollBoost = Math.min(scrollBoost + delta * 0.05, 6);
        lastScrollY = window.scrollY;
      },
      { passive: true }
    );

    window.addEventListener('resize', calcHalf);

    calcHalf();
    tick();
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.sort_by_type.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.sort_by_type.heading",
      "default": "Sort by type"
    }
  ],
  "presets": [
    {
      "name": "t:sections.sort_by_type.name"
    }
  ]
}
{% endschema %}
