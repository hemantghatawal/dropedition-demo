<section class="living-room full-width" id="living-room">
  {%- comment -%} Heading {%- endcomment -%}
  <div class="living-room__header">
    <h2 class="living-room__heading">{{ section.settings.heading | escape }}</h2>
  </div>

  {%- comment -%} Asymmetric image grid {%- endcomment -%}
  <div class="living-room__grid">
    {%- comment -%} Large left image {%- endcomment -%}
    <div class="living-room__cell living-room__cell--large">
      <img
        src="{{ 'living-room-1.avif' | asset_url }}"
        alt="{{ section.settings.heading | escape }}"
        class="living-room__img"
        loading="lazy"
        width="800"
        height="1000"
      >
    </div>

    {%- comment -%} Right column — pure 2x2 grid, bottom-right is Shop Now {%- endcomment -%}
    <div class="living-room__col-right">
      <div class="living-room__right-grid">
        <div class="living-room__cell living-room__cell--small">
          <img
            src="{{ 'living-room-2.avif' | asset_url }}"
            alt="{{ section.settings.heading | escape }}"
            class="living-room__img"
            loading="lazy"
            width="400"
            height="400"
          >
        </div>

        <div class="living-room__cell living-room__cell--small">
          <img
            src="{{ 'living-room-3.avif' | asset_url }}"
            alt="{{ section.settings.heading | escape }}"
            class="living-room__img"
            loading="lazy"
            width="400"
            height="400"
          >
        </div>

        <div class="living-room__cell living-room__cell--small">
          <img
            src="{{ 'living-room-4.avif' | asset_url }}"
            alt="{{ section.settings.heading | escape }}"
            class="living-room__img"
            loading="lazy"
            width="400"
            height="400"
          >
        </div>

        {%- comment -%} Bottom-right: Shop Now CTA {%- endcomment -%}
        <div class="living-room__cell living-room__cell--cta">
          <button class="living-room__cta" type="button">
            <span class="living-room__cta-label">{{ section.settings.cta_label | escape }}</span>
            <svg
              class="living-room__cta-arrow"
              width="80"
              height="12"
              viewBox="0 0 80 12"
              fill="none"
              stroke="currentColor"
              stroke-width="1.2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <line x1="0" y1="6" x2="80" y2="6"/>
              <polyline points="72,0 80,6 72,12"/>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .living-room {
    width: 100%;
    padding: var(--space-xl) var(--page-margin);
    font-family: var(--font-primary);
  }

  /* ── Heading ── */
  .living-room__header {
    margin-bottom: var(--space-lg);
  }

  .living-room__heading {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-fg);
    margin: 0;
  }

  /* ── Grid layout ── */
  .living-room__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: var(--space-sm);
    align-items: stretch;
    height: 70vh;
    min-height: 480px;
  }

  /* ── Left large image fills full grid height ── */
  .living-room__cell--large {
    height: 100%;
  }

  /* ── Right column fills full grid height ── */
  .living-room__col-right {
    height: 100%;
  }

  /* ── 2x2 equal grid fills right column height ── */
  .living-room__right-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: var(--space-sm);
    height: 70vh;
  }

  /* ── Image cells ── */
  .living-room__cell {
    overflow: hidden;
    background-color: var(--color-secondary);
  }

  .living-room__cell--large {
    height: 70vh;
    min-height: 480px;
  }

  .living-room__cell--small {
    min-height: 140px;
  }

  /* ── CTA cell — bottom-right box ── */
  .living-room__cell--cta {
    background-color: var(--color-fg);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 140px;
  }

  .living-room__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform var(--transition-slow);
  }

  .living-room__cell:hover .living-room__img {
    transform: scale(1.03);
  }

  /* ── CTA button inside dark box ── */
  .living-room__cta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-sm);
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-md);
    color: var(--color-text-light);
    font-family: var(--font-primary);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    width: 100%;
    height: 100%;
    transition: opacity var(--transition-fast);
  }

  .living-room__cta:hover {
    opacity: 0.8;
  }

  .living-room__cta-arrow {
    flex-shrink: 0;
    transition: transform var(--transition-base);
  }

  .living-room__cta:hover .living-room__cta-arrow {
    transform: translateX(6px);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .living-room__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 768px) {
    .living-room__grid {
      grid-template-columns: 1fr;
    }

    .living-room__cell--large {
      height: 55vw;
      min-height: 280px;
    }

    .living-room__cell--top-right {
      height: 45vw;
      min-height: 200px;
    }

    .living-room__cell--bottom-right,
    .living-room__cell--extra {
      height: 40vw;
      min-height: 160px;
    }

    .living-room__cta-wrap {
      justify-content: flex-start;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.living_room.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.living_room.heading",
      "default": "Living room"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "t:sections.living_room.cta_label",
      "default": "Shop now"
    }
  ],
  "presets": [
    {
      "name": "t:sections.living_room.name"
    }
  ]
}
{% endschema %}
