<footer class="footer full-width" id="footer">
  {%- comment -%} Aldrich font for footer only {%- endcomment -%}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Aldrich&display=swap" rel="stylesheet">
  {%- comment -%} Background video {%- endcomment -%}
  <div class="footer__video-bg">
    <video
      class="footer__video"
      autoplay
      muted
      loop
      playsinline
      aria-hidden="true"
    >
      <source src="{{ section.settings.video_url | escape }}" type="video/mp4">
    </video>
  </div>

  {%- comment -%} Glass card {%- endcomment -%}
  <div class="footer__glass">
    {%- comment -%} Top grid: 4 columns {%- endcomment -%}
    <div class="footer__grid">
      {%- comment -%} Col 1: Drops {%- endcomment -%}
      <div class="footer__col">
        <h3 class="footer__col-heading">{{ 'sections.footer.drops' | t }}</h3>
        <ul class="footer__list">
          {%- if section.settings.drops_menu.links.size > 0 -%}
            {%- for link in section.settings.drops_menu.links -%}
              <li>
                <a href="{{ link.url }}" class="footer__link">{{ link.title }}</a>
              </li>
            {%- endfor -%}
          {%- else -%}
            <li><a href="/collections/drop-6" class="footer__link">Drop 6</a></li>
            <li><a href="/collections/drop-7" class="footer__link">Drop 7</a></li>
          {%- endif -%}
        </ul>
      </div>

      {%- comment -%} Col 2: Stores {%- endcomment -%}
      <div class="footer__col">
        <h3 class="footer__col-heading">{{ 'sections.footer.stores' | t }}</h3>
        <ul class="footer__list">
          {%- if section.settings.stores_menu.links.size > 0 -%}
            {%- for link in section.settings.stores_menu.links -%}
              <li>
                <a href="{{ link.url }}" class="footer__link">{{ link.title }}</a>
              </li>
            {%- endfor -%}
          {%- else -%}
            <li><a href="#" class="footer__link">H.LORENZO</a></li>
            <li><a href="#" class="footer__link">CURVE</a></li>
          {%- endif -%}
        </ul>
      </div>

      {%- comment -%} Col 3: Information {%- endcomment -%}
      <div class="footer__col">
        <h3 class="footer__col-heading">{{ 'sections.footer.information' | t }}</h3>
        <ul class="footer__list">
          {%- if section.settings.info_menu.links.size > 0 -%}
            {%- for link in section.settings.info_menu.links -%}
              <li>
                <a href="{{ link.url }}" class="footer__link">{{ link.title }}</a>
              </li>
            {%- endfor -%}
          {%- else -%}
            <li><a href="/pages/contact" class="footer__link">Contact</a></li>
            <li><a href="/policies/refund-policy" class="footer__link">Return and Refunds</a></li>
            <li><a href="/policies/privacy-policy" class="footer__link">Privacy Policy</a></li>
            <li><a href="/policies/terms-of-service" class="footer__link">Terms of Service</a></li>
          {%- endif -%}
        </ul>
      </div>

      {%- comment -%} Col 4: About us {%- endcomment -%}
      <div class="footer__col">
        <h3 class="footer__col-heading">{{ 'sections.footer.about_us' | t }}</h3>
        <p class="footer__about-text">
          Drop Edition is the co-creation of Jieun Kim and Mimi Kim, two entrepreneurial women with careers in fashion
          spanning from Seoul to Tokyo, to LA and NYC.
        </p>
        <p class="footer__about-text">
          Drop Edition is a Smart contemporary clothing designed for your goals. Versatile pieces, compact collection,
          endless style possibilities.
        </p>
      </div>
    </div>

    {%- comment -%} Bottom bar {%- endcomment -%}
    <div class="footer__bottom">
      <div class="footer__bottom-left">
        {%- if section.settings.instagram_url != blank -%}
          <a
            href="{{ section.settings.instagram_url }}"
            class="footer__social-link"
            aria-label="Instagram"
            target="_blank"
            rel="noopener"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
            </svg>
          </a>
        {%- endif -%}
        <p class="footer__copyright">&copy; 2025, Drop Edition Powered by square43.com</p>
      </div>
      <div class="footer__bottom-right">
        <img
          src="https://dropedition.com/images/logo-white.svg"
          alt="Drop Edition"
          class="footer__logo"
          width="520"
          height="auto"
        >
      </div>
    </div>
  </div>
</footer>

{% stylesheet %}
  .footer {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: flex;
    align-items: stretch;
    font-family: 'Aldrich', sans-serif;
  }

  /* ── Video background ── */
  .footer__video-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .footer__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* ── Glass card ── */
  .footer__glass {
    position: relative;
    z-index: 1;
    width: calc(100% - 4rem);
    max-width: 1900px;
    margin: 4rem auto;
    background: rgba(40, 55, 50, 0.72);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 4rem 3rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: clamp(420px, 72vh, 900px);
  }

  /* ── 4-column grid ── */
  .footer__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    margin-bottom: 0;
  }

  .footer__col-heading {
    font-size: clamp(0.9rem, 1.5vw, 1.4rem);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #fff;
    margin: 0 0 1rem;
  }

  .footer__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .footer__link {
    font-size: clamp(0.8rem, 1.2vw, 1.36rem);
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.2s;
  }

  .footer__link:hover {
    color: #fff;
  }

  .footer__about-text {
    font-size: clamp(0.75rem, 1.1vw, 1.3rem);
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.7;
    margin: 0 0 0.6rem;
  }

  .footer__about-text:last-child {
    margin-bottom: 0;
  }

  /* ── Bottom bar ── */
  .footer__bottom {
    display: grid;
    grid-template-columns: 30% 70%;
    align-items: end;
    margin-top: 0;
    margin-bottom: 0;
  }

  .footer__bottom-left {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-bottom: 0.5rem;
  }

  .footer__social-link {
    color: rgba(255, 255, 255, 0.75);
    transition: color 0.2s;
    display: inline-flex;
  }

  .footer__social-link:hover {
    color: #fff;
  }

  .footer__copyright {
    font-size: clamp(0.65rem, 0.9vw, 1rem);
    color: rgba(255, 255, 255, 0.55);
    letter-spacing: 0.04em;
    margin: 0;
  }

  .footer__copyright a {
    color: inherit;
    text-decoration: none;
  }

  .footer__bottom-right {
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
  }

  .footer__logo {
    max-width: 100%;
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Laptop (< 1600px) ── */
  @media (max-width: 1600px) {
    .footer__glass {
      width: calc(100% - 6rem);
      margin: 3rem auto;
      min-height: clamp(380px, 68vh, 800px);
    }
  }

  /* ── Small laptop (< 1200px) ── */
  @media (max-width: 1200px) {
    .footer__glass {
      width: calc(100% - 4rem);
      margin: 2rem auto;
      min-height: clamp(340px, 62vh, 700px);
    }

    .footer__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }
  }

  /* ── Tablet ── */
  @media (max-width: 900px) {
    .footer {
      height: auto;
    }

    .footer__glass {
      width: calc(100% - 3rem);
      margin: 1.5rem auto;
      padding: 2.5rem 2rem;
      min-height: clamp(300px, 55vh, 600px);
    }

    .footer__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }

    .footer__bottom {
      grid-template-columns: 40% 60%;
    }
  }

  /* ── Mobile ── */
  @media (max-width: 560px) {
    .footer {
      height: auto;
    }

    .footer__glass {
      width: calc(100% - 2rem);
      margin: 1rem auto;
      padding: 2rem 1.25rem 1.5rem;
      min-height: clamp(480px, 80vh, 700px);
    }

    .footer__grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .footer__bottom {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .footer__bottom-right {
      justify-content: flex-start;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    {
      "type": "text",
      "id": "video_url",
      "label": "t:sections.footer.video_url",
      "default": "https://dropedition.com/videos/footer-video.mp4"
    },
    {
      "type": "link_list",
      "id": "drops_menu",
      "label": "t:sections.footer.drops_menu"
    },
    {
      "type": "link_list",
      "id": "stores_menu",
      "label": "t:sections.footer.stores_menu"
    },
    {
      "type": "link_list",
      "id": "info_menu",
      "label": "t:sections.footer.info_menu"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "t:sections.footer.instagram_url"
    }
  ]
}
{% endschema %}
