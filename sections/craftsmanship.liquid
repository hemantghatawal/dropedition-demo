<section class="craftsmanship full-width" id="craftsmanship">
  {%- comment -%} Parallax background {%- endcomment -%}
  <div class="craftsmanship__bg" id="craftsmanship-bg">
    {%- if section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 2400 }}"
        alt=""
        class="craftsmanship__bg-img"
        loading="lazy"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}"
      >
    {%- else -%}
      <img
        src="{{ 'craftsmanship.jpg' | asset_url }}"
        alt=""
        class="craftsmanship__bg-img"
        loading="lazy"
        width="2400"
        height="1350"
      >
    {%- endif -%}
    <div class="craftsmanship__overlay"></div>
  </div>

  {%- comment -%} Content {%- endcomment -%}
  <div class="craftsmanship__content">
    <h2 class="craftsmanship__heading">
      {{- section.settings.heading | escape -}}
    </h2>

    <p class="craftsmanship__text craftsmanship__text--left">
      {{- section.settings.text_left | escape -}}
    </p>
    <p class="craftsmanship__text craftsmanship__text--right">
      {{- section.settings.text_right | escape -}}
    </p>
  </div>
</section>

{% stylesheet %}
  .craftsmanship {
    position: relative;
    width: 100%;
    min-height: 100vh;
    overflow: hidden;
    font-family: var(--font-primary);
  }

  /* ── Parallax background ── */
  .craftsmanship__bg {
    position: absolute;
    inset: -15%;
    z-index: 0;
    will-change: transform;
  }

  .craftsmanship__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .craftsmanship__overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.55);
  }

  /* ── Content ── */
  .craftsmanship__content {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100vh;
    max-width: var(--page-width);
    margin: 0 auto;
    padding: var(--space-xl) var(--page-margin);
  }

  /* ── Heading: top center ── */
  .craftsmanship__heading {
    font-size: clamp(3rem, 8vw, 7rem);
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--color-text-light);
    text-align: center;
    margin: 0 0 0 0;
    line-height: 1;
  }

  /* ── Diagonal text layout ── */
  .craftsmanship__text {
    position: absolute;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-regular);
    color: var(--color-text-light);
    line-height: 1.8;
    opacity: 0.85;
    margin: 0;
    letter-spacing: 0.5em; /* starts wide, JS steps it down */
    max-width: 320px;
    transition: letter-spacing 0.7s ease;
  }

  .craftsmanship__text--left {
    top: 25%;
    left: var(--page-margin);
  }

  .craftsmanship__text--right {
    bottom: 10%;
    right: var(--page-margin);
    text-align: right;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .craftsmanship__heading {
      letter-spacing: 0.2em;
    }

    .craftsmanship__text {
      position: static;
      max-width: 100%;
      text-align: left;
      margin-top: var(--space-lg);
    }

    .craftsmanship__text--right {
      text-align: left;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var section = document.getElementById('craftsmanship');
    var bg = document.getElementById('craftsmanship-bg');
    var texts = section ? section.querySelectorAll('.craftsmanship__text') : [];

    if (!section || !bg) return;

    /* ── Parallax ── */
    function onScroll() {
      var rect = section.getBoundingClientRect();
      var vh = window.innerHeight;
      var progress = 1 - rect.bottom / (vh + rect.height);
      var clampedP = Math.min(Math.max(progress, 0), 1);
      bg.style.transform = 'translateY(' + (clampedP - 0.5) * 30 + '%)';
    }

    /* ── Letter-spacing animation (runs once on enter) ── */
    var animated = false;

    function animateTexts() {
      if (animated) return;
      animated = true;

      /* Step 1 → mid spacing after 1s */
      setTimeout(function () {
        texts.forEach(function (el) {
          el.style.letterSpacing = '0.25em';
        });
      }, 1000);

      /* Step 2 → tighter after 2s */
      setTimeout(function () {
        texts.forEach(function (el) {
          el.style.letterSpacing = '0.12em';
        });
      }, 2000);

      /* Step 3 → normal after 3s */
      setTimeout(function () {
        texts.forEach(function (el) {
          el.style.letterSpacing = '0.04em';
        });
      }, 3000);
    }

    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) animateTexts();
        });
      },
      { threshold: 0.3 }
    );

    observer.observe(section);

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  })();
{% endjavascript %}

