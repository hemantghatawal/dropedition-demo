<section class="craftsmanship full-width" id="craftsmanship">
  {%- comment -%} Parallax background {%- endcomment -%}
  <div class="craftsmanship__bg" id="craftsmanship-bg">
    {%- if section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 2400 }}"
        alt=""
        class="craftsmanship__bg-img"
        loading="lazy"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}"
      >
    {%- else -%}
      <img
        src="{{ 'craftsmanship.jpg' | asset_url }}"
        alt=""
        class="craftsmanship__bg-img"
        loading="lazy"
        width="2400"
        height="1350"
      >
    {%- endif -%}
    <div class="craftsmanship__overlay"></div>
  </div>

  {%- comment -%} Content {%- endcomment -%}
  <div class="craftsmanship__content">
    <h2 class="craftsmanship__heading">
      {{- section.settings.heading | escape -}}
    </h2>

    <div class="craftsmanship__text craftsmanship__text--left">
      <p class="craftsmanship__line">Handcrafted with intention,</p>
      <p class="craftsmanship__line">built to endure the test</p>
      <p class="craftsmanship__line">of time and taste.</p>
    </div>

    <div class="craftsmanship__text craftsmanship__text--right">
      <p class="craftsmanship__line">worth keeping for gens</p>
      <p class="craftsmanship__line">Always a story to tells</p>
      <p class="craftsmanship__line">worth keeping, always.</p>
    </div>
  </div>
</section>

{% stylesheet %}
  .craftsmanship {
    position: relative;
    width: 100%;
    min-height: 100vh;
    overflow: hidden;
    font-family: var(--font-primary);
  }

  /* ── Parallax background ── */
  .craftsmanship__bg {
    position: absolute;
    inset: -15%;
    z-index: 0;
    will-change: transform;
  }

  .craftsmanship__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .craftsmanship__overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.55);
  }

  /* ── Content ── */
  .craftsmanship__content {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100vh;
    max-width: var(--page-width);
    margin: 0 auto;
    padding: var(--space-xl) var(--page-margin);
  }

  /* ── Heading: top center ── */
  .craftsmanship__heading {
    font-size: clamp(2rem, 6vw, 7rem);
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--color-text-light);
    text-align: center;
    margin: 0;
    line-height: 1;
  }

  /* ── Diagonal text layout ── */
  .craftsmanship__text {
    position: absolute;
    font-weight: var(--font-weight-regular);
    color: var(--color-text-light);
    line-height: 1.6;
    opacity: 0.85;
    margin: 0;
  }

  .craftsmanship__text--left {
    top: 25%;
    left: var(--page-margin);
    font-size: clamp(0.85rem, 1.2vw, 1.1rem);
    max-width: 480px;
  }

  .craftsmanship__text--right {
    bottom: 10%;
    left: 55%;
    text-align: left;
    font-size: clamp(2.5rem, 4vw, 3.3rem);
    line-height: 1.2;
  }

  .craftsmanship__text--right .craftsmanship__line {
    white-space: nowrap !important;
  }

  /* ── Per-line animation ── */
  .craftsmanship__line {
    margin: 0 0 0.3em;
    white-space: nowrap;
  }

  .craftsmanship__char {
    display: inline-block;
    letter-spacing: 0.5em;
    transition: letter-spacing 0.6s ease;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .craftsmanship__heading {
      font-size: clamp(1.4rem, 8vw, 3rem);
      letter-spacing: 0.05em;
      word-break: break-word;
      overflow-wrap: break-word;
      white-space: normal;
      padding: 0 var(--page-margin);
    }

    .craftsmanship__text {
      position: static;
      max-width: 100%;
      margin-top: var(--space-lg);
    }

    .craftsmanship__text--left {
      font-size: clamp(0.85rem, 3.5vw, 1rem);
      text-align: left;
    }

    .craftsmanship__text--right {
      position: absolute;
      bottom: 5%;
      left: 50%;
      transform: translateX(-50%);
      font-size: clamp(1.4rem, 6vw, 2rem);
      text-align: left;
      width: auto;
      max-width: 100%;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var section = document.getElementById('craftsmanship');
    var bg = document.getElementById('craftsmanship-bg');

    if (!section || !bg) return;

    /* ── Parallax ── */
    function onScroll() {
      var rect = section.getBoundingClientRect();
      var vh = window.innerHeight;
      var progress = 1 - rect.bottom / (vh + rect.height);
      var clampedP = Math.min(Math.max(progress, 0), 1);
      bg.style.transform = 'translateY(' + (clampedP - 0.5) * 30 + '%)';
    }

    /* ── Split each line into per-char spans ── */
    function splitChars() {
      var lines = section.querySelectorAll('.craftsmanship__line');
      lines.forEach(function (line) {
        var text = line.textContent;
        line.textContent = '';
        text.split('').forEach(function (char) {
          var span = document.createElement('span');
          span.className = 'craftsmanship__char';
          span.textContent = char === ' ' ? '\u00A0' : char;
          line.appendChild(span);
        });
      });
    }

    /* ── Animate chars: all lines together, random order ── */
    var animated = false;

    function animateChars() {
      if (animated) return;
      animated = true;

      var chars = section.querySelectorAll('.craftsmanship__char');

      chars.forEach(function (char) {
        var delay = Math.random() * 1200; /* random delay up to 1200ms */

        setTimeout(function () {
          char.style.letterSpacing = '0.25em';
        }, delay);
        setTimeout(function () {
          char.style.letterSpacing = '0.12em';
        }, delay + 400);
        setTimeout(function () {
          char.style.letterSpacing = '0.04em';
        }, delay + 800);
      });
    }

    splitChars();

    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) animateChars();
        });
      },
      { threshold: 0.3 }
    );

    observer.observe(section);

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    /* ── Device orientation parallax (mobile/tablet gyroscope) ── */
    /* iPadOS 13+ reports as 'Macintosh', so we use touch + orientation feature detection */
    var isMobile =
      /Mobi|Android|iPhone|iPad/i.test(navigator.userAgent) ||
      (navigator.maxTouchPoints > 1 && /Macintosh/i.test(navigator.userAgent));

    if (isMobile && window.DeviceOrientationEvent) {
      var gyroX = 0;
      var gyroY = 0;
      var currentX = 0;
      var currentY = 0;
      var rafId = null;

      function smoothGyro() {
        currentX += (gyroX - currentX) * 0.08;
        currentY += (gyroY - currentY) * 0.08;

        /* Blend gyro offset on top of scroll parallax */
        var rect = section.getBoundingClientRect();
        var vh = window.innerHeight;
        var progress = 1 - rect.bottom / (vh + rect.height);
        var clampedP = Math.min(Math.max(progress, 0), 1);
        var scrollY = (clampedP - 0.5) * 30;

        bg.style.transform = 'translateY(' + (scrollY + currentY) + '%) translateX(' + currentX + '%)';

        rafId = requestAnimationFrame(smoothGyro);
      }

      function onOrientation(e) {
        /* beta: front-back tilt (-180 to 180), gamma: left-right tilt (-90 to 90) */
        var beta = e.beta || 0;
        var gamma = e.gamma || 0;

        /* Clamp and normalise to a small offset range */
        gyroY = Math.min(Math.max(beta - 45, -30), 30) * 0.08;
        gyroX = Math.min(Math.max(gamma, -30), 30) * 0.06;
      }

      /* iOS 13+ requires permission */
      if (typeof DeviceOrientationEvent.requestPermission === 'function') {
        document.addEventListener(
          'click',
          function requestOnce() {
            DeviceOrientationEvent.requestPermission().then(function (state) {
              if (state === 'granted') {
                window.addEventListener('deviceorientation', onOrientation, { passive: true });
                smoothGyro();
              }
            });
            document.removeEventListener('click', requestOnce);
          },
          { once: true }
        );
      } else {
        window.addEventListener('deviceorientation', onOrientation, { passive: true });
        smoothGyro();
      }
    }
  })();
{% endjavascript %}

{% schema %}
